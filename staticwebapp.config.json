{
  "routes": [
    {
      "route": "_next/static/*",
      "headers": {
        "cache-control": "must-revalidate, max-age=15770000"
      }
    },
    {
      "route": "*.{png,jpg,gif,xml,ico,css,js}",
      "headers": {
        "cache-control": "must-revalidate, max-age=15770000"
      }
    },
    {
      "route": "/assets/*",
      "headers": {
        "cache-control": "must-revalidate, max-age=15770000"
      }
    },
    {
      "route": "/login",
      "rewrite": "/.auth/login/aad"
    },
    {
      "route": "/.auth/login/twitter",
      "statusCode": 404
    },
    {
      "route": "/.auth/login/github",
      "statusCode": 404
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout?post_logout_redirect_uri=/LogoutRedirect"
    },
    {
      "route": "/api/ExecSAMSetup",
      "allowedRoles": ["admin", "editor", "readonly", "authenticated", "anonymous"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/AddStandardTemplate",
      "allowedRoles": ["admin"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/RemoveStandardTemplate",
      "allowedRoles": ["admin"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/LogoutRedirect",
      "allowedRoles": ["admin", "editor", "readonly", "authenticated", "anonymous"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/404",
      "allowedRoles": ["admin", "editor", "readonly", "authenticated", "anonymous"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/RemoveStandard",
      "allowedRoles": ["admin"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/add*",
      "allowedRoles": ["admin", "editor"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/edit*",
      "allowedRoles": ["admin", "editor"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/ExecSendPush",
      "allowedRoles": ["admin", "editor", "readonly"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/ExecExcludeTenant",
      "allowedRoles": ["admin"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/Exec*",
      "allowedRoles": ["admin", "editor"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/Remove*",
      "allowedRoles": ["admin", "editor"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/cipp/*",
      "allowedRoles": ["admin"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/tenant/standards/*",
      "allowedRoles": ["admin"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/",
      "allowedRoles": ["admin", "editor", "readonly", "reader"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/Public*",
      "allowedRoles": ["admin", "editor", "readonly", "reader", "authenticated", "anonymous"],
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "*",
      "allowedRoles": ["admin", "editor", "readonly", "reader"],
      "headers": {
        "Cache-Control": "no-store"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "index.html",
    "exclude": [
      "_next/static/*",
      "/css/*",
      "public/*",
      "assets/*",
      "favicon.ico",
      "robots.txt",
      "sitemap.xml",
      "manifest.json"
    ]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302,
      "exclude": ["/assets/illustrations/*.{png,jpg,gif}", "/css/*"]
    },
    "403": {
      "rewrite": "/403"
    },
    "404": {
      "rewrite": "/404"
    }
  },
  "globalHeaders": {
    "content-security-policy": "default-src https: blob: 'unsafe-eval' 'unsafe-inline'; object-src 'self' blob:; img-src 'self' blob: data: *"
  },
  "mimeTypes": {
    ".json": "text/json"
  },
  "networking": {
    "allowedIpRanges": ["AzureFrontDoor.Backend"]
  },
  "forwardingGateway": {
    "requiredHeaders": {
      "X-Azure-FDID": "cc02277f-9d64-4b99-8857-ef07e03c555c"
    },
    "allowedForwardedHosts": [
      "CIPP-gwh4b5faaberhnbp.z03.azurefd.net",
      "cipp.priority.works"
      "mango-wave-062e36f0f.4.azurestaticapps.net"
    ]
  }
}
